{
  "enabled": true,
  "name": "Lint ao commitar",
  "description": "Executa o ESLint automaticamente antes de cada commit para garantir que o código segue os padrões de qualidade do projeto.",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      ".*commit.*"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint"
  }
}